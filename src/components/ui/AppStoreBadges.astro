---
import HugeIcon from './HugeIcon';
---

<div class="flex flex-wrap justify-center lg:justify-start gap-4">
  <!-- iOS Download Button -->
  <a 
    href="/downloads/baguiostride.ipa" 
    download
    class="inline-flex items-center gap-3 px-6 py-3 bg-green-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl"
  >
    <HugeIcon client:load name="ios" className="w-6 h-6 text-white" size={24} />
    <span>Download for iOS</span>
  </a>
  
  <!-- Android Download Button -->
  <a 
    href="/downloads/baguiostride.apk" 
    download
    class="inline-flex items-center gap-3 px-6 py-3 bg-orange-600 hover:bg-green-700 text-white font-semibold rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl"
  >
    <HugeIcon client:load name="android" className="w-6 h-6 text-white" size={24} />
    <span>Download for Android</span>
  </a>
</div>
