---
import HugeIcon from './HugeIcon';
---

<div class="flex flex-col sm:flex-row flex-wrap justify-center lg:justify-start gap-3 sm:gap-4">
  <!-- iOS Download Button -->
  <a 
    href="/downloads/baguiostride.ipa" 
    download
    class="inline-flex items-center justify-center gap-2 sm:gap-3 px-5 sm:px-6 py-2.5 sm:py-3 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl text-sm sm:text-base w-full sm:w-auto"
  >
    <HugeIcon client:load name="ios" className="w-5 h-5 sm:w-6 sm:h-6 text-white" size={24} />
    <span>Download for iOS</span>
  </a>
  
  <!-- Android Download Button -->
  <a 
    href="/downloads/baguiostride.apk" 
    download="baguiostride.apk"
    class="inline-flex items-center justify-center gap-2 sm:gap-3 px-5 sm:px-6 py-2.5 sm:py-3 bg-orange-600 hover:bg-orange-700 text-white font-semibold rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl text-sm sm:text-base w-full sm:w-auto"
  >
    <HugeIcon client:load name="android" className="w-5 h-5 sm:w-6 sm:h-6 text-white" size={24} />
    <span>Download for Android</span>
  </a>
</div>
