---
import StarRating from './StarRating';

interface Props {
  name: string;
  role: string;
  rating: number;
  text: string;
  avatar?: string;
}

const { name, role, rating, text, avatar } = Astro.props;
---

<div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow duration-300">
  <!-- Rating -->
  <div class="mb-4">
    <StarRating client:load rating={rating} size={20} />
  </div>
  
  <!-- Testimonial Text -->
  <p class="text-gray-700 mb-6 italic">"{text}"</p>
  
  <!-- Author -->
  <div class="flex items-center gap-4">
    <div class="w-12 h-12 bg-primary/20 rounded-full flex items-center justify-center">
      {avatar ? (
        <img src={avatar} alt={name} class="w-full h-full rounded-full object-cover" />
      ) : (
        <span class="text-primary font-bold">{name.charAt(0)}</span>
      )}
    </div>
    <div>
      <p class="font-semibold text-gray-900">{name}</p>
      <p class="text-sm text-gray-600">{role}</p>
    </div>
  </div>
</div>

