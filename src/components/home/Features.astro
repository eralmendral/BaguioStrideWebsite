---
import FeatureIcon from '../ui/FeatureIcon';

const features = [
  {
    icon: 'message-circle',
    title: 'AI Chatbot',
    subtitle: "Just Ask, We'll Guide",
    description:
      'Type or speak your destination. Our AI understands natural language and finds the best route instantly.',
    color: 'primary' as const,
  },
  {
    icon: 'ai-voice',
    title: 'Voice Search',
    subtitle: 'Hands-Free Navigation',
    description: "Speak your destination in English or Tagalog. Perfect when you're on the move.",
    color: 'secondary' as const,
  },
  {
    icon: 'map-pin',
    title: 'Real-Time GPS',
    subtitle: 'Always Know Where You Are',
    description: 'Live location tracking ensures you never miss your stop or terminal.',
    color: 'accent' as const,
  },
  {
    icon: 'route',
    title: 'Step-by-Step Guidance',
    subtitle: 'Turn-by-Turn Instructions',
    description: 'From your hotel to the terminal, we guide you every step with clear directions.',
    color: 'primary' as const,
  },
  {
    icon: 'magic-wand',
    title: 'Smart Recommendations',
    subtitle: 'Discover Hidden Gems',
    description: 'Get personalized tourist spot suggestions along your route.',
    color: 'secondary' as const,
  },
  {
    icon: 'calculator',
    title: 'Fare Calculator',
    subtitle: 'Budget Your Trip',
    description: 'Know exactly how much your journey will cost before you board.',
    color: 'accent' as const,
  },
];
---

<section id="features" class="bg-white py-12 sm:py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-10 sm:mb-12 lg:mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-3 sm:mb-4 px-2">
        Your Intelligent <span class="text-primary">Travel Companion</span>
      </h2>
      <p class="text-base sm:text-lg lg:text-xl text-gray-600 max-w-3xl mx-auto px-4 sm:px-0">
        Everything you need to navigate Baguio's jeepney system with confidence
      </p>
    </div>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {features.map((feature) => (
        <div class="group rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:shadow-lg sm:p-6">
          <div class={`w-12 h-12 sm:w-14 sm:h-14 ${
            feature.color === 'primary' ? 'bg-primary/10 text-primary' :
            feature.color === 'secondary' ? 'bg-secondary/10 text-secondary' :
            'bg-accent/10 text-accent'
          } rounded-lg flex items-center justify-center mb-3 sm:mb-4 group-hover:scale-105 transition-transform`}>
            <FeatureIcon client:load icon={feature.icon} className="w-6 h-6 sm:w-7 sm:h-7" />
          </div>
          <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-2">{feature.title}</h3>
          <p class="text-sm sm:text-base text-primary font-semibold mb-2 sm:mb-3">
            {feature.subtitle}
          </p>
          <p class="text-sm sm:text-base text-gray-600">{feature.description}</p>
        </div>
      ))}
    </div>
    
  </div>
</section>
