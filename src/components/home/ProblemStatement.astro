---
import HugeIcon from '../ui/HugeIcon';
---

<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Lost in Transit? <span class="text-primary">We've Got You Covered</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Navigating Baguio's jeepney system can be overwhelming. We understand the challenges you face.
      </p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8">
      
      <!-- Problem Card 1 -->
      <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow duration-300">
        <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-6">
          <HugeIcon client:load name="route-confused" className="w-8 h-8 text-red-600" size={32} />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-3">Confusing Routes</h3>
        <p class="text-gray-600">
          Don't know which jeepney goes where? Multiple routes, unclear signage, and constantly changing paths make navigation difficult.
        </p>
      </div>
      
      <!-- Problem Card 2 -->
      <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow duration-300">
        <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mb-6">
          <HugeIcon client:load name="language" className="w-8 h-8 text-orange-600" size={32} />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-3">Language Barriers</h3>
        <p class="text-gray-600">
          Can't communicate your destination? Local terms and unfamiliar place names make it hard to ask for directions or understand route information.
        </p>
      </div>
      
      <!-- Problem Card 3 -->
      <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow duration-300">
        <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mb-6">
          <HugeIcon client:load name="clock" className="w-8 h-8 text-yellow-600" size={32} />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-3">Time Wasted</h3>
        <p class="text-gray-600">
          Spending hours figuring out transportation? Wrong routes, missed stops, and endless walking waste precious vacation or commute time.
        </p>
      </div>
      
    </div>
  </div>
</section>

