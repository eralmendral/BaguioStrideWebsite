---
import AppStoreBadges from '../ui/AppStoreBadges.astro';
import HugeIcon from '../ui/HugeIcon';
---

<section
  class="relative flex min-h-[92svh] items-center overflow-hidden bg-stone-50 pt-20 sm:pt-24"
>
  <div
    class="absolute inset-0 opacity-60"
    style="background-image: linear-gradient(rgba(46, 125, 50, 0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(25, 118, 210, 0.08) 1px, transparent 1px); background-size: 44px 44px;"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8 lg:py-20">
    <div class="grid items-center gap-10 lg:grid-cols-[1.02fr_0.98fr] lg:gap-12">
      <div class="text-center lg:text-left">
        <p
          class="mx-auto mb-4 inline-flex rounded-full border border-primary/20 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-wide text-primary shadow-sm lg:mx-0"
        >
          Baguio jeepney routes, simplified
        </p>

        <h1
          class="mx-auto mb-5 max-w-4xl text-4xl font-bold leading-tight text-gray-950 sm:text-5xl md:text-6xl lg:mx-0 lg:text-7xl"
        >
          Navigate Baguio <span class="text-primary">like a local</span>
        </h1>

        <p
          class="mx-auto mb-7 max-w-2xl px-2 text-lg text-gray-600 sm:px-0 sm:text-xl md:text-2xl lg:mx-0"
        >
          Ask where to go, get the right jeepney route, and know what to expect before you ride.
        </p>

        <div class="mt-6">
          <AppStoreBadges />
        </div>

        <div
          class="mt-8 grid max-w-xl grid-cols-3 gap-3 text-left sm:gap-4 lg:mx-0"
        >
          <div class="rounded-lg border border-gray-200 bg-white p-3 shadow-sm">
            <p class="text-lg font-bold text-gray-950">AI</p>
            <p class="text-xs text-gray-600">Route search</p>
          </div>
          <div class="rounded-lg border border-gray-200 bg-white p-3 shadow-sm">
            <p class="text-lg font-bold text-gray-950">GPS</p>
            <p class="text-xs text-gray-600">Stop alerts</p>
          </div>
          <div class="rounded-lg border border-gray-200 bg-white p-3 shadow-sm">
            <p class="text-lg font-bold text-gray-950">Fare</p>
            <p class="text-xs text-gray-600">Trip estimates</p>
          </div>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-2xl">
        <div class="grid grid-cols-[0.78fr_1fr] items-end gap-4 sm:gap-6">
          <div class="hidden sm:block">
            <div class="overflow-hidden rounded-lg border border-gray-200 bg-white p-2 shadow-xl">
              <div class="aspect-[9/19.5] overflow-hidden rounded-md bg-gray-100">
                <img
                  src="/images/2.PNG"
                  alt="BaguioStride route guidance screen"
                  class="h-full w-full object-cover"
                  loading="eager"
                />
              </div>
            </div>
          </div>

          <div class="relative">
            <div class="overflow-hidden rounded-lg border border-gray-900 bg-gray-950 p-2 shadow-2xl sm:p-3">
              <div class="aspect-[9/19.5] overflow-hidden rounded-md bg-white">
                <img
                  src="/images/1.PNG"
                  alt="BaguioStride destination search screen"
                  class="h-full w-full object-cover"
                  loading="eager"
                />
              </div>
            </div>
            <div
              class="absolute -bottom-5 left-1/2 w-[86%] -translate-x-1/2 rounded-lg border border-gray-200 bg-white p-4 shadow-xl"
            >
              <p class="text-xs font-semibold uppercase tracking-wide text-secondary">Next ride</p>
              <div class="mt-2 flex items-center justify-between gap-4">
                <div>
                  <p class="font-bold text-gray-950">Burnham Park</p>
                  <p class="text-xs text-gray-600">Walk 3 min to terminal</p>
                </div>
                <p class="whitespace-nowrap rounded-md bg-primary px-3 py-1 text-sm font-bold text-white">
                  ~₱15
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce">
    <HugeIcon client:load name="arrow-down" className="w-6 h-6 text-gray-400" size={24} />
  </div>
</section>
