---
import AppStoreBadges from '../ui/AppStoreBadges.astro';
import HugeIcon from '../ui/HugeIcon';
---

<section id="download" class="py-24 bg-gradient-to-br from-primary via-primary-dark to-secondary relative overflow-hidden">
  <div class="absolute inset-0 bg-black/10"></div>
  
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center">
      
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
        Ready to Navigate Baguio Like a Local?
      </h2>
      
      <p class="text-xl md:text-2xl text-white/90 mb-12 max-w-2xl mx-auto">
        Download BaguioStride today and experience stress-free navigation in the City of Pines.
      </p>
      
      <div class="mb-8">
        <AppStoreBadges />
      </div>
      
      <div class="flex flex-wrap justify-center gap-6 text-white/80 text-sm">
        <div class="flex items-center gap-2">
          <HugeIcon client:load name="check" className="w-5 h-5" size={20} />
          <span>Free to Download</span>
        </div>
        <div class="flex items-center gap-2">
          <HugeIcon client:load name="check" className="w-5 h-5" size={20} />
          <span>No Ads</span>
        </div>
        <div class="flex items-center gap-2">
          <HugeIcon client:load name="check" className="w-5 h-5" size={20} />
          <span>Works Offline</span>
        </div>
      </div>
      
    </div>
  </div>
  
  <!-- Decorative Elements -->
  <div class="absolute top-0 left-0 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
</section>

