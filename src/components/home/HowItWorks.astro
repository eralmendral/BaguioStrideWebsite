---
---

<section id="how-it-works" class="py-12 sm:py-16 lg:py-24 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-10 sm:mb-12 lg:mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-3 sm:mb-4 px-2">
        Getting Around Baguio in <span class="text-primary">3 Easy Steps</span>
      </h2>
      <p class="text-base sm:text-lg lg:text-xl text-gray-600 px-4 sm:px-0">
        From planning to arrival, we've got you covered
      </p>
    </div>
    
    <div class="relative">
      <!-- Connecting Line (desktop) -->
      <div class="hidden lg:block absolute top-1/2 left-0 right-0 h-1 bg-gradient-to-r from-primary via-secondary to-accent transform -translate-y-1/2 z-0"></div>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 sm:gap-10 lg:gap-12 relative z-10">
        
        <!-- Step 1 -->
        <div class="text-center sm:col-span-2 lg:col-span-1">
          <div class="relative inline-block mb-4 sm:mb-6">
            <div class="w-16 h-16 sm:w-20 sm:h-20 bg-primary rounded-full flex items-center justify-center text-white text-2xl sm:text-3xl font-bold shadow-lg relative z-10">
              1
            </div>
            <div class="absolute -top-2 -right-2 w-6 h-6 sm:w-8 sm:h-8 bg-accent rounded-full animate-ping"></div>
          </div>
          <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mb-3 sm:mb-4">Tell Us Where You Want to Go</h3>
          <p class="text-sm sm:text-base text-gray-600 mb-4 sm:mb-6 px-2">
            Type or speak your destination. Our AI understands you instantly.
          </p>
          <div class="bg-white rounded-2xl shadow-xl p-3 sm:p-4 max-w-xs mx-auto">
            <div class="aspect-[9/19.5] rounded-xl overflow-hidden">
              <img 
                src="/images/1.PNG" 
                alt="Step 1: Tell Us Where You Want to Go" 
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </div>
        
        <!-- Step 2 -->
        <div class="text-center sm:col-span-2 lg:col-span-1">
          <div class="relative inline-block mb-4 sm:mb-6">
            <div class="w-16 h-16 sm:w-20 sm:h-20 bg-secondary rounded-full flex items-center justify-center text-white text-2xl sm:text-3xl font-bold shadow-lg relative z-10">
              2
            </div>
            <div class="absolute -top-2 -right-2 w-6 h-6 sm:w-8 sm:h-8 bg-accent rounded-full animate-ping"></div>
          </div>
          <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mb-3 sm:mb-4">Follow Our Guided Route</h3>
          <p class="text-sm sm:text-base text-gray-600 mb-4 sm:mb-6 px-2">
            Get turn-by-turn directions with real-time GPS tracking and stop alerts.
          </p>
          <div class="bg-white rounded-2xl shadow-xl p-3 sm:p-4 max-w-xs mx-auto">
            <div class="aspect-[9/19.5] rounded-xl overflow-hidden">
              <img 
                src="/images/2.PNG" 
                alt="Step 2: Follow Our Guided Route" 
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </div>
        
        <!-- Step 3 -->
        <div class="text-center sm:col-span-2 lg:col-span-1">
          <div class="relative inline-block mb-4 sm:mb-6">
            <div class="w-16 h-16 sm:w-20 sm:h-20 bg-accent rounded-full flex items-center justify-center text-white text-2xl sm:text-3xl font-bold shadow-lg relative z-10">
              3
            </div>
            <div class="absolute -top-2 -right-2 w-6 h-6 sm:w-8 sm:h-8 bg-primary rounded-full animate-ping"></div>
          </div>
          <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mb-3 sm:mb-4">Arrive at Your Destination</h3>
          <p class="text-sm sm:text-base text-gray-600 mb-4 sm:mb-6 px-2">
            Reach your destination confidently with accurate arrival times and fare information.
          </p>
          <div class="bg-white rounded-2xl shadow-xl p-3 sm:p-4 max-w-xs mx-auto">
            <div class="aspect-[9/19.5] rounded-xl overflow-hidden">
              <img 
                src="/images/3.PNG" 
                alt="Step 3: Arrive at Your Destination" 
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</section>

