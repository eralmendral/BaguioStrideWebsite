---
---

<section id="how-it-works" class="py-24 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Getting Around Baguio in <span class="text-primary">3 Easy Steps</span>
      </h2>
      <p class="text-xl text-gray-600">
        From planning to arrival, we've got you covered
      </p>
    </div>
    
    <div class="relative">
      <!-- Connecting Line (desktop) -->
      <div class="hidden lg:block absolute top-1/2 left-0 right-0 h-1 bg-gradient-to-r from-primary via-secondary to-accent transform -translate-y-1/2 z-0"></div>
      
      <div class="grid md:grid-cols-3 gap-12 relative z-10">
        
        <!-- Step 1 -->
        <div class="text-center">
          <div class="relative inline-block mb-6">
            <div class="w-20 h-20 bg-primary rounded-full flex items-center justify-center text-white text-3xl font-bold shadow-lg relative z-10">
              1
            </div>
            <div class="absolute -top-2 -right-2 w-8 h-8 bg-accent rounded-full animate-ping"></div>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Tell Us Where You Want to Go</h3>
          <p class="text-gray-600 mb-6">
            Type or speak your destination. Our AI understands you instantly.
          </p>
          <div class="bg-white rounded-2xl shadow-xl p-4">
            <div class="aspect-[9/19.5] bg-gradient-to-br from-primary/20 to-secondary/20 rounded-xl flex items-center justify-center">
              <div class="text-center">
                <div class="w-16 h-16 bg-primary/30 rounded-full mx-auto mb-3 flex items-center justify-center">
                  <span class="text-3xl">📍</span>
                </div>
                <p class="text-sm text-gray-600">Step 1 Preview</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Step 2 -->
        <div class="text-center">
          <div class="relative inline-block mb-6">
            <div class="w-20 h-20 bg-secondary rounded-full flex items-center justify-center text-white text-3xl font-bold shadow-lg relative z-10">
              2
            </div>
            <div class="absolute -top-2 -right-2 w-8 h-8 bg-accent rounded-full animate-ping"></div>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Follow Our Guided Route</h3>
          <p class="text-gray-600 mb-6">
            Get turn-by-turn directions with real-time GPS tracking and stop alerts.
          </p>
          <div class="bg-white rounded-2xl shadow-xl p-4">
            <div class="aspect-[9/19.5] bg-gradient-to-br from-secondary/20 to-accent/20 rounded-xl flex items-center justify-center">
              <div class="text-center">
                <div class="w-16 h-16 bg-secondary/30 rounded-full mx-auto mb-3 flex items-center justify-center">
                  <span class="text-3xl">🗺️</span>
                </div>
                <p class="text-sm text-gray-600">Step 2 Preview</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Step 3 -->
        <div class="text-center">
          <div class="relative inline-block mb-6">
            <div class="w-20 h-20 bg-accent rounded-full flex items-center justify-center text-white text-3xl font-bold shadow-lg relative z-10">
              3
            </div>
            <div class="absolute -top-2 -right-2 w-8 h-8 bg-primary rounded-full animate-ping"></div>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Arrive at Your Destination</h3>
          <p class="text-gray-600 mb-6">
            Reach your destination confidently with accurate arrival times and fare information.
          </p>
          <div class="bg-white rounded-2xl shadow-xl p-4">
            <div class="aspect-[9/19.5] bg-gradient-to-br from-accent/20 to-primary/20 rounded-xl flex items-center justify-center">
              <div class="text-center">
                <div class="w-16 h-16 bg-accent/30 rounded-full mx-auto mb-3 flex items-center justify-center">
                  <span class="text-3xl">✅</span>
                </div>
                <p class="text-sm text-gray-600">Step 3 Preview</p>
              </div>
            </div>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</section>

