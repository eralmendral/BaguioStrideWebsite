---
---

<section class="py-12 sm:py-16 lg:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-10 sm:mb-12 lg:mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-3 sm:mb-4 px-2">
        Popular Routes <span class="text-primary">Made Easy</span>
      </h2>
      <p class="text-base sm:text-lg lg:text-xl text-gray-600 px-4 sm:px-0">
        Navigate to Baguio's most popular destinations with confidence
      </p>
    </div>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      
      <!-- Route Card 1 -->
      <div class="bg-gradient-to-br from-primary/10 to-primary/5 rounded-2xl p-5 sm:p-6 border-2 border-primary/20 hover:border-primary/40 transition-all duration-300">
        <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-primary rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-xl sm:text-2xl">🏔️</span>
          </div>
          <div>
            <h3 class="text-lg sm:text-xl font-bold text-gray-900">Burnham Park</h3>
            <p class="text-xs sm:text-sm text-gray-600">City Center</p>
          </div>
        </div>
        <p class="text-sm sm:text-base text-gray-700 mb-3 sm:mb-4">
          Navigate to Baguio's iconic park with step-by-step jeepney directions from anywhere in the city.
        </p>
        <div class="flex items-center justify-between text-xs sm:text-sm">
          <span class="text-primary font-semibold">~₱15 fare</span>
          <span class="text-gray-600">15-20 min</span>
        </div>
      </div>
      
      <!-- Route Card 2 -->
      <div class="bg-gradient-to-br from-secondary/10 to-secondary/5 rounded-2xl p-5 sm:p-6 border-2 border-secondary/20 hover:border-secondary/40 transition-all duration-300">
        <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-secondary rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-xl sm:text-2xl">⛪</span>
          </div>
          <div>
            <h3 class="text-lg sm:text-xl font-bold text-gray-900">Our Lady of Lourdes</h3>
            <p class="text-xs sm:text-sm text-gray-600">Grotto</p>
          </div>
        </div>
        <p class="text-sm sm:text-base text-gray-700 mb-3 sm:mb-4">
          Find the best route to the famous grotto with real-time updates and fare information.
        </p>
        <div class="flex items-center justify-between text-xs sm:text-sm">
          <span class="text-secondary font-semibold">~₱20 fare</span>
          <span class="text-gray-600">25-30 min</span>
        </div>
      </div>
      
      <!-- Route Card 3 -->
      <div class="bg-gradient-to-br from-accent/10 to-accent/5 rounded-2xl p-5 sm:p-6 border-2 border-accent/20 hover:border-accent/40 transition-all duration-300">
        <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-accent rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-xl sm:text-2xl">🎨</span>
          </div>
          <div>
            <h3 class="text-lg sm:text-xl font-bold text-gray-900">Tam-Awan Village</h3>
            <p class="text-xs sm:text-sm text-gray-600">Cultural Site</p>
          </div>
        </div>
        <p class="text-sm sm:text-base text-gray-700 mb-3 sm:mb-4">
          Discover the cultural heart of Baguio with detailed navigation and tourist spot recommendations.
        </p>
        <div class="flex items-center justify-between text-xs sm:text-sm">
          <span class="text-accent font-semibold">~₱25 fare</span>
          <span class="text-gray-600">30-35 min</span>
        </div>
      </div>
      
      <!-- Route Card 4 -->
      <div class="bg-gradient-to-br from-primary/10 to-primary/5 rounded-2xl p-5 sm:p-6 border-2 border-primary/20 hover:border-primary/40 transition-all duration-300">
        <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-primary rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-xl sm:text-2xl">🛍️</span>
          </div>
          <div>
            <h3 class="text-lg sm:text-xl font-bold text-gray-900">SM City Baguio</h3>
            <p class="text-xs sm:text-sm text-gray-600">Shopping Mall</p>
          </div>
        </div>
        <p class="text-sm sm:text-base text-gray-700 mb-3 sm:mb-4">
          Get to the city's main shopping destination with accurate route planning and stop alerts.
        </p>
        <div class="flex items-center justify-between text-xs sm:text-sm">
          <span class="text-primary font-semibold">~₱12 fare</span>
          <span class="text-gray-600">10-15 min</span>
        </div>
      </div>
      
      <!-- Route Card 5 -->
      <div class="bg-gradient-to-br from-secondary/10 to-secondary/5 rounded-2xl p-5 sm:p-6 border-2 border-secondary/20 hover:border-secondary/40 transition-all duration-300">
        <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-secondary rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-xl sm:text-2xl">🌲</span>
          </div>
          <div>
            <h3 class="text-lg sm:text-xl font-bold text-gray-900">Mines View Park</h3>
            <p class="text-xs sm:text-sm text-gray-600">Scenic Viewpoint</p>
          </div>
        </div>
        <p class="text-sm sm:text-base text-gray-700 mb-3 sm:mb-4">
          Experience Baguio's stunning views with reliable navigation to this popular tourist spot.
        </p>
        <div class="flex items-center justify-between text-xs sm:text-sm">
          <span class="text-secondary font-semibold">~₱18 fare</span>
          <span class="text-gray-600">20-25 min</span>
        </div>
      </div>
      
      <!-- Route Card 6 -->
      <div class="bg-gradient-to-br from-accent/10 to-accent/5 rounded-2xl p-5 sm:p-6 border-2 border-accent/20 hover:border-accent/40 transition-all duration-300">
        <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-accent rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-xl sm:text-2xl">🏛️</span>
          </div>
          <div>
            <h3 class="text-lg sm:text-xl font-bold text-gray-900">Baguio Cathedral</h3>
            <p class="text-xs sm:text-sm text-gray-600">Historic Church</p>
          </div>
        </div>
        <p class="text-sm sm:text-base text-gray-700 mb-3 sm:mb-4">
          Visit the iconic cathedral with easy-to-follow directions and historical context along the way.
        </p>
        <div class="flex items-center justify-between text-xs sm:text-sm">
          <span class="text-accent font-semibold">~₱15 fare</span>
          <span class="text-gray-600">15-20 min</span>
        </div>
      </div>
      
    </div>
  </div>
</section>

