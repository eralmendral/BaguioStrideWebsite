---
import HugeIcon from '../ui/HugeIcon';
---

<footer class="bg-gray-900 text-gray-300 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center space-x-2 mb-4">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
            <HugeIcon client:load name="route" className="text-white" size={20} strokeWidth={2} />
          </div>
          <span class="text-xl font-bold text-white">BaguioStride</span>
        </div>
        <p class="text-sm text-gray-400">
          Navigate Baguio like a local with AI-powered jeepney route guidance.
        </p>
      </div>
      
      <!-- Download -->
      <div>
        <h3 class="text-white font-semibold mb-4">Download</h3>
        <div class="flex flex-wrap gap-3">
          <!-- iOS Download Button -->
          <a 
            href="/downloads/baguiostride.ipa" 
            download
            class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-lg transition-all duration-200 shadow-md hover:shadow-lg"
          >
            <HugeIcon client:load name="ios" className="w-5 h-5 text-white" size={20} />
            <span>iOS</span>
          </a>
          
          <!-- Android Download Button -->
          <button
            id="footer-android-download-btn"
            class="inline-flex items-center gap-2 px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-lg transition-all duration-200 shadow-md hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <HugeIcon client:load name="android" className="w-5 h-5 text-white" size={20} />
            <span id="footer-android-download-text">Android</span>
          </button>
        </div>
      </div>
    </div>
    
    <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm text-gray-400">
      <p>&copy; 2024 BaguioStride. All rights reserved.</p>
    </div>
  </div>
</footer>

<script>
  // Check if Android APK exists before allowing download
  (async function() {
    const androidBtn = document.getElementById('footer-android-download-btn');
    const androidText = document.getElementById('footer-android-download-text');
    
    if (!androidBtn || !androidText || !(androidBtn instanceof HTMLButtonElement)) return;
    
    try {
      // Check if APK file exists by making a HEAD request
      const response = await fetch('/downloads/baguiostride.apk', { method: 'HEAD' });
      
      if (response.ok && response.headers.get('content-length') && parseInt(response.headers.get('content-length') || '0') > 100000) {
        // File exists and is large enough (more than 100KB), convert button to link
        const link = document.createElement('a');
        link.href = '/downloads/baguiostride.apk';
        link.download = 'baguiostride.apk';
        link.className = androidBtn.className;
        link.innerHTML = androidBtn.innerHTML;
        androidBtn.replaceWith(link);
      } else {
        // File doesn't exist or is too small, show coming soon message
        androidBtn.disabled = true;
        androidText.textContent = 'Android (Soon)';
        androidBtn.title = 'Android APK is currently being built. Please check back soon!';
      }
    } catch (error) {
      // File doesn't exist, show coming soon message
      androidBtn.disabled = true;
      androidText.textContent = 'Android (Soon)';
      androidBtn.title = 'Android APK is currently being built. Please check back soon!';
    }
  })();
</script>

