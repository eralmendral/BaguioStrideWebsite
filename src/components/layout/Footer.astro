---
import AppStoreBadges from '../ui/AppStoreBadges.astro';
import HugeIcon from '../ui/HugeIcon';
---

<footer class="bg-gray-900 text-gray-300 py-8 sm:py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid sm:grid-cols-2 gap-6 sm:gap-8">
      <!-- Brand -->
      <div class="text-center sm:text-left">
        <div class="flex items-center justify-center sm:justify-start space-x-2 mb-3 sm:mb-4">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
            <HugeIcon client:load name="route" className="text-white" size={20} strokeWidth={2} />
          </div>
          <span class="text-lg sm:text-xl font-bold text-white">BaguioStride</span>
        </div>
        <p class="text-xs sm:text-sm text-gray-400 max-w-md mx-auto sm:mx-0">
          Navigate Baguio like a local with AI-powered jeepney route guidance.
        </p>
      </div>
      
      <!-- Download -->
      <div class="text-center sm:text-left">
        <h3 class="text-white font-semibold mb-3 sm:mb-4 text-base sm:text-lg">Download</h3>
        <AppStoreBadges align="footer" compact={true} />
      </div>
    </div>
    
    <div class="border-t border-gray-800 mt-6 sm:mt-8 pt-6 sm:pt-8 text-center text-xs sm:text-sm text-gray-400">
      <p>&copy; 2024 BaguioStride. All rights reserved.</p>
    </div>
  </div>
</footer>
